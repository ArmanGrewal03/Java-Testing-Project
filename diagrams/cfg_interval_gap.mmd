flowchart TD
    A([Start gap interval]) --> B[interval = getReadableInterval interval]
    B --> C[Load bounds: otherStart, otherEnd, thisStart, thisEnd]
    C --> D{thisStart greater than otherEnd?}
    D -- Yes --> E[return Interval otherEnd to thisStart]
    D -- No --> F{otherStart greater than thisEnd?}
    F -- Yes --> G[return Interval thisEnd to otherStart]
    F -- No --> H[return null]
    E --> I([End])
    G --> I
    H --> I
