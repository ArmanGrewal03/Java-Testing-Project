flowchart TD
    A([Start gap(interval)]) --> B[interval = getReadableInterval(interval)]
    B --> C[Load otherStart, otherEnd, thisStart, thisEnd]
    C --> D{thisStart > otherEnd?}
    D -- Yes --> E[return new Interval(otherEnd, thisStart, chronology)]
    D -- No --> F{otherStart > thisEnd?}
    F -- Yes --> G[return new Interval(thisEnd, otherStart, chronology)]
    F -- No --> H[return null]
    E --> I([End])
    G --> I
    H --> I
